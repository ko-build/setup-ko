{
  "name": "setup-ko",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Action to install and setup ko",
  "main": "dist/setup/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc && ncc build -o dist/setup src/setup-ko.ts",
    "format": "prettier --no-error-on-unmatched-pattern --config ./.prettierrc.js --write \"**/*.{ts,yml,yaml}\"",
    "format-check": "prettier --no-error-on-unmatched-pattern --config ./.prettierrc.js --check \"**/*.{ts,yml,yaml}\"",
    "lint": "eslint --config ./.eslintrc.js \"**/*.ts\"",
    "lint:fix": "eslint --config ./.eslintrc.js \"**/*.ts\" --fix",
    "test": "jest --coverage",
    "pre-checkin": "pnpm run format && pnpm run lint:fix && pnpm run build && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ko-build/setup-ko.git"
  },
  "keywords": [
    "actions",
    "ko",
    "setup"
  ],
  "author": "ko-build",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/github": "^6.0.1",
    "@actions/tool-cache": "^3.0.1",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.35.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.3.2",
    "typescript": "^5.9.3"
  }
}
