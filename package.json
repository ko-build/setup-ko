{
  "name": "setup-ko",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Action to install and setup ko",
  "main": "dist/setup/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc && ncc build -o dist/setup src/setup-ko.ts",
    "format": "prettier --no-error-on-unmatched-pattern --config ./.prettierrc.js --write \"**/*.{ts,yml,yaml}\"",
    "format-check": "prettier --no-error-on-unmatched-pattern --config ./.prettierrc.js --check \"**/*.{ts,yml,yaml}\"",
    "lint": "eslint --config ./.eslintrc.js \"**/*.ts\"",
    "lint:fix": "eslint --config ./.eslintrc.js \"**/*.ts\" --fix",
    "test": "jest --coverage",
    "pre-checkin": "pnpm run format && pnpm run lint:fix && pnpm run build && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ko-build/setup-ko.git"
  },
  "keywords": [
    "actions",
    "ko",
    "setup"
  ],
  "author": "ko-build",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.8.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vercel/ncc": "^0.38.4",
    "babel-jest": "^30.4.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-n": "^18.1.0",
    "jest": "^30.4.2",
    "jest-circus": "^30.4.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
